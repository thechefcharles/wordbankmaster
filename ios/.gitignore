App/build
App/output
App/App/public

# CocoaPods (created by `pod install`)
Pods/
App/App.xcworkspace/xcuserdata/

# Xcode user/local state
DerivedData/
xcuserdata/

# Local Xcode environment overrides (machine-specific NODE_BINARY, etc.)
.xcode.env.local

# Cordova plugins for Capacitor
capacitor-cordova-ios-plugins

# SPM resolved package manifest is regenerated by `cap sync` / Xcode package
# resolution — don't track the lockfile it produces.
**/xcshareddata/swiftpm/Package.resolved

# Generated Config files
App/App/capacitor.config.json
App/App/config.xml

# NOTE (repo-size debt): previously-tracked generated artifacts (e.g. the
# Package.resolved removed above) were only ever committed in this squashed
# single-commit snapshot, so there is no deeper history to rewrite from here.
# If the canonical remote history is large, purge it there with
# `git filter-repo` (or BFG) and force-push separately/coordinate with the team.
